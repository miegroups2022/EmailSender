        ['Step1TemplatePanel',  '模版选择 + 预览 + AI优化'],
        ['Step2ListPanel',      '列表选择 + 清洗过滤 + 实时统计'],
        ['Step3SettingsPanel',  '发送时间/间隔/线程/通道设置'],
    ]
)

