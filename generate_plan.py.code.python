    'public enum SendStatus   { Pending, Sent, Delivered, Opened,',
    '                           Clicked, Bounced, Failed, Spam }',
    '',
    '// 发送通道',
    'public enum SendChannel  { SendCloud, Gmail, Hotmail, SMTP }',
    '',
    '// 账户类型',
    'public enum AccountType  { SendCloud, Gmail, Hotmail, SMTP }',
    '',
    '// 邮件地址验证状态',
    'public enum VerifyStatus { Unknown, Valid, Invalid, CatchAll, SpamTrap }',
    '',
    '// 黑名单类型',
    'public enum BlacklistType{ Manual, HardBounce, SpamReport,',
    '                           Unsubscribe, RepeatedFail, Invalid }',
])

