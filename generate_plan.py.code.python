#  四、关键数据流图
# ══════════════════════════════════════════════════════════════
add_heading('四、关键数据流图', 1)

add_heading('4.1  新建任务完整流程', 2)
add_code_block([
    '用户点击[新建任务]',
    '    │',
    '    ▼',
    'Step1: 选模版',
    '    ├── MeetbyApiClient.GetTemplates()',
    '    ├── 本地预览 WebBrowser',
    '    ├── [AI分析] → AiAnalysisService → 显示评分',
    '    ├── [修改]   → 本地保存，标记 NeedResync=1',
    '    └── [同步到SendCloud] → SendCloudApiClient.UploadTemplate()',
    '                           标记 SyncedToSendCloud=1',
    '    │',
    '    ▼',
    'Step2: 选邮件列表',
    '    ├── MeetbyApiClient.GetEmailLists()',
    '    ├── [下载]      → EmailListService.DownloadAndSave()',
    '    ├── [验证无效]  → ZeroBounce API → 更新 VerifyStatus',
    '    ├── [去黑名单]  → BlacklistService.Filter()',
    '    ├── [去失败N次] → EmailListService.FilterByFailCount()',
    '    ├── [去已发送]  → EmailListService.FilterSent()',
    '    ├── [去本周已发]→ EmailListService.FilterSentThisWeek()',
    '    └── 实时显示: 剩余数量 + 域名分布',
    '    │',
    '    ▼',
    'Step3: 发送设置',
    '    ├── 选择发送时间（立即/定时）',
    '    ├── 设置间隔/线程数/重试次数',
    '    ├── 选择发送通道（SendCloud/Gmail/Hotmail/SMTP）',
    '    └── [确认创建任务]',
    '    │',
    '    ▼',
    '任务写入 SendTask 表，状态: Pending',
])

add_heading('4.2  发送执行流程', 2)
add_code_block([
    'SendTaskService.ExecuteTask(taskId)',
    '    │',
    '    ├── 读取任务配置',
    '    ├── 读取过滤后的邮件地址列表',
    '    ├── 初始化 SemaphoreSlim(threadCount)',
    '    │',
    '    ├── foreach email in list:',
    '    │       ├── await semaphore.WaitAsync()',
    '    │       ├── 按通道分流发送',
    '    │       │     ├── SendCloud: 提交模版发送请求',
    '    │       │     ├── Gmail/Hotmail: OAuth Token → SmtpClient',
    '    │       │     └── SMTP: TemplateRenderer拼内容 → SmtpClient',
    '    │       ├── 写入 SendRecord（Status=Sent/Failed）',
    '    │       ├── await Task.Delay(interval)',
    '    │       └── semaphore.Release()',
    '    │',
    '    └── 更新 SendTask.Status = Done',
])

add_heading('4.3  结果刷新流程', 2)
add_code_block([
    'ResultFetchService.FetchPendingResults(taskId)',
    '    │',
    '    ├── SELECT * FROM SendRecord',
    '    │   WHERE TaskId=? AND ResultFetched=0  LIMIT 100',
    '    │',
    '    ├── 提取 SendCloudMsgId 列表',
    '    │',
    '    ├── 调用 SendCloud GET /apiv2/log/list',
    '    │   参数: msgIds / 时间范围',
    '    │',
    '    ├── 逐条更新 SendRecord:',
    '    │   ├── SendStatus = Delivered/Opened/Bounced...',
    '    │   ├── ResultFetched = 1',
    '    │   └── FetchedAt = Now',
    '    │',
    '    ├── 汇总统计写回 SendTask:',
    '    │   ├── SuccessCount / FailCount / OpenCount',
    '    │   └── 各百分比',
    '    │',
    '    └── 刷新 UI DataGridView 显示',
])

