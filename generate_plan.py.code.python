add_para('MeetbyApiClient.cs', bold=True)
add_code_block([
    'Login(username, password)          → 返回 Token',
    'GetTemplates(token)                → 返回模版列表',
    'GetEmailLists(token)               → 返回邮件列表',
    'GetEmailListMembers(token, listId) → 返回邮件地址列表',
])

add_para('SendCloudApiClient.cs', bold=True)
add_code_block([
    'UploadTemplate(template)           → 上传/更新模版到SendCloud',
    'SendByTemplate(taskConfig)         → 模版发送',
    'QuerySendLog(startDate, endDate)   → 查询发送日志',
])

add_para('SendEngineService.cs — 核心发送引擎', bold=True)
add_code_block([
    '发送流程：',
    '1. 读取任务配置（通道/线程数/间隔/重试次数）',
    '2. 按通道分流：',
    '   ├── SendCloud → 调用 SendCloudApiClient',
    '   ├── Gmail    → 调用 OAuthHelper + SmtpClient',
    '   ├── Hotmail  → 调用 OAuthHelper + SmtpClient',
    '   └── SMTP     → 直接 SmtpClient + TemplateRenderer 拼内容',
    '3. 多线程控制（SemaphoreSlim 控制并发数）',
    '4. 发送间隔控制（Task.Delay）',
    '5. 失败重试（RetryCount < RetryMax）',
    '6. 实时更新进度（IProgress<T>）',
    '7. 支持取消（CancellationToken）',
])

add_para('ResultFetchService.cs — 结果轮询', bold=True)
add_code_block([
    'FetchPendingResults(taskId):',
    '1. 查询 SendRecord WHERE ResultFetched=0',
    '2. 取出 SendCloudMsgId 列表',
    '3. 批量调用 SendCloud /apiv2/log/list',
    '4. 更新 SendRecord.SendStatus / ResultFetched=1',
    '5. 汇总更新 SendTask 统计字段',
])

add_para('AiAnalysisService.cs — AI 分析', bold=True)
add_code_block([
    'AnalyzeTemplate(subject, htmlBody):',
    '1. 构建 Prompt（主题/内容/反垃圾规则）',
    '2. 调用 DeepSeek / OpenAI API',
    '3. 解析返回 JSON { score, issues[], suggestions[] }',
    '4. 保存到 EmailTemplate.AiScore / AiSuggestions',
])

add_para('EmailListService.cs — 列表清洗', bold=True)
add_code_block([
    'DownloadAndSave(listId)            → 下载并去重存库',
    'FilterBlacklist()                  → 过滤黑名单',
    'FilterByFailCount(minFail)         → 按失败次数过滤',
    'FilterSent()                       → 过滤已发送',
    'FilterSentThisWeek()               → 过滤本周已发',
    'VerifyWithZeroBounce(emails)       → 调用ZeroBounce批量验证',
    'GetDomainStats()                   → 返回域名分布统计',
])

