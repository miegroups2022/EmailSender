<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <ProjectGuid>{44444444-4444-4444-4444-444444444444}</ProjectGuid>
    <OutputType>WinExe</OutputType>
    <RootNamespace>EmailSender.UI</RootNamespace>
    <AssemblyName>EmailSender</AssemblyName>
    <TargetFramework>net8.0-windows</TargetFramework>
    <UseWindowsForms>true</UseWindowsForms>
    <LangVersion>latest</LangVersion>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <GenerateAssemblyInfo>true</GenerateAssemblyInfo>
    <!-- 允许在 WinForms 设计器中使用 -->
    <UseWPF>false</UseWPF>
    <!-- 发布时生成单文件（可选） -->
    <!-- <PublishSingleFile>true</PublishSingleFile> -->
    <!-- <SelfContained>true</SelfContained> -->
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="..\EmailSender.Models\EmailSender.Models.csproj" />
    <ProjectReference Include="..\EmailSender.Data\EmailSender.Data.csproj" />
    <ProjectReference Include="..\EmailSender.Core\EmailSender.Core.csproj" />
  </ItemGroup>

  <ItemGroup>
    <!-- JSON 序列化 -->
    <PackageReference Include="Newtonsoft.Json" Version="13.0.3" />

    <!-- 异步接口（统一版本） -->
    <PackageReference Include="Microsoft.Bcl.AsyncInterfaces" Version="9.0.1" />
  </ItemGroup>

  <!-- Mock JSON 文件：复制到输出目录 -->
  <ItemGroup>
    <Content Include="mock\auth_login.json">
      <CopyToOutputDirectory>Always</CopyToOutputDirectory>
    </Content>
    <Content Include="mock\templates.json">
      <CopyToOutputDirectory>Always</CopyToOutputDirectory>
    </Content>
    <Content Include="mock\recipients.json">
      <CopyToOutputDirectory>Always</CopyToOutputDirectory>
    </Content>
  </ItemGroup>

</Project>
