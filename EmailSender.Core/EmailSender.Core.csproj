<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <ProjectGuid>{33333333-3333-3333-3333-333333333333}</ProjectGuid>
    <OutputType>Library</OutputType>
    <RootNamespace>EmailSender.Core</RootNamespace>
    <AssemblyName>EmailSender.Core</AssemblyName>
    <TargetFramework>net8.0-windows</TargetFramework>
    <LangVersion>latest</LangVersion>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <GenerateAssemblyInfo>true</GenerateAssemblyInfo>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="..\EmailSender.Models\EmailSender.Models.csproj" />
    <ProjectReference Include="..\EmailSender.Data\EmailSender.Data.csproj" />
  </ItemGroup>

  <ItemGroup>
    <!-- 邮件发送 -->
    <PackageReference Include="Google.Apis" Version="1.74.0" />
    <PackageReference Include="Google.Apis.Core" Version="1.74.0" />
    <PackageReference Include="MailKit" Version="4.16.0" />
    <PackageReference Include="Microsoft.Identity.Client" Version="4.84.0" />
    <PackageReference Include="MimeKit" Version="4.16.0" />

    <!-- HTTP 客户端 -->
    <PackageReference Include="Newtonsoft.Json" Version="13.0.4" />

    <!-- OAuth / Google -->
    <PackageReference Include="Google.Apis.Auth" Version="1.74.0" />

    <!-- 加密 -->
    <PackageReference Include="BouncyCastle.Cryptography" Version="2.6.2" />

    <!-- 压缩 -->
    <PackageReference Include="K4os.Compression.LZ4" Version="1.3.8" />
    <PackageReference Include="K4os.Compression.LZ4.Streams" Version="1.3.8" />

    <!-- Protobuf -->
    <PackageReference Include="Google.Protobuf" Version="3.34.1" />

    <!-- 异步接口（统一版本） -->
    <PackageReference Include="Microsoft.Bcl.AsyncInterfaces" Version="10.0.7" />
  </ItemGroup>

</Project>
